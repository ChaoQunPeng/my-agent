# ============================================
# 项目结构说明
# ============================================

# 前端相关文件 (Client/Vue3 + Vite)
client/dist/              # 前端构建输出目录
client/.vite/            # Vite 缓存目录
client/node_modules/     # 前端依赖

# 后端相关文件 (Server/NestJS)
server/dist/             # 后端构建输出目录
server/node_modules/     # 后端依赖
server/.nest/            # NestJS 缓存目录

# 根目录可能的前端构建产物 (如果存在 monorepo 构建)
/dist/                   # 可能是前端或后端构建产物，根据实际项目配置
/build/                  # 可能是前端或后端构建产物，根据实际项目配置
