# 开发环境配置

# Mock API 配置 (开发环境下启用 mock 接口)
# 当 request.ts 中 customDev: true 时，会将 baseURL 替换为 /
# 这样请求才能匹配到 mock-h3 注册的 /api/* 路由
VITE_APP_MOCK_API=/

# 路由加载方式 (FRONTEND: 前端动态加载，BACKEND: 后端加载)
VITE_APP_LOAD_ROUTE_WAY=FRONTEND

# 以下配置已废弃，因为现在使用 mock-h3 而不是 Vite 代理
# VITE_APP_BASE_API_DEV=/api
# VITE_APP_BASE_URL_DEV=http://localhost:3000
# VITE_APP_BASE=/
